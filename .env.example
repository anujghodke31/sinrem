# ============================================================
# .env.example — Copy to .env and fill in your real values
# NEVER commit .env — it is listed in .gitignore
# ============================================================

PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────
# Local dev:   mongodb://127.0.0.1:27017/sinrem
# Production:  your MongoDB Atlas connection string
MONGO_URI=mongodb://127.0.0.1:27017/sinrem

# ── JWT ───────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Must be ≥32 characters. Keep secret. Rotate if exposed.
JWT_SECRET=replace_with_128_char_random_hex_string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Email (Nodemailer / Gmail SMTP) ───────────────────────────
# Requires a Gmail App Password (NOT your Gmail password):
#   1. Enable 2-Step Verification: myaccount.google.com/security
#   2. Create App Password: myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password

# Notification recipient for contact form & job applications
ADMIN_EMAIL=your_email@gmail.com

# ── Admin seed credentials ─────────────────────────────────────
# Used ONLY by: npm run seed
# Password must be ≥12 characters with mixed case + special chars
ADMIN_USERNAME=admin
ADMIN_PASSWORD=YourStrongPassword12!

# ── CORS whitelist ─────────────────────────────────────────────
# Development: http://localhost:5000
# Production:  https://sinrem.tech
FRONTEND_URL=http://localhost:5000
